# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/telegram_main/
!groups/global/
groups/telegram_main/*
groups/global/*
!groups/telegram_main/CLAUDE.md
!groups/global/CLAUDE.md

# Secrets
*.keys.json
.env

# Generated on target hosts by deploy.sh (qmd push-sync config)
.qmd-sync.json

# Agent overlays - track everything except secrets
agents/*/.env

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs
