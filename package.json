{
  "name": "nanoclaw",
  "version": "1.2.42",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && ./scripts/svc.sh restart",
    "svc": "./scripts/svc.sh",
    "svc:logs": "tail -f logs/nanoclaw.log",
    "svc:errors": "tail -f logs/nanoclaw.error.log",
    "container:build": "./container/build.sh",
    "container:build:clean": "docker builder prune -f && ./container/build.sh",
    "container:test": "./scripts/test-container.sh",
    "container:push-runner": "./scripts/push-runner.sh",
    "container:logs": "docker logs -f $(docker ps --filter name=nanoclaw- --format '{{.Names}}' | head -1)",
    "container:exec": "docker exec -it $(docker ps --filter name=nanoclaw- --format '{{.Names}}' | head -1) /bin/bash",
    "container:restart": "./container/build.sh && ./scripts/push-runner.sh && docker rm -f $(docker ps -q --filter name=nanoclaw- | head -1) 2>/dev/null; echo 'Container restart ready — next message will spawn a fresh container.'",
    "tool-logs": "(sleep 0.3 && open http://localhost:8713/tools/log-viewer.html) & python3 -m http.server 8713"
  },
  "dependencies": {
    "@onecli-sh/sdk": "^0.2.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "dotenv-cli": "^11.0.0",
    "grammy": "^1.39.3",
    "playwright": "^1.58.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
